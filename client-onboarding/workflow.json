    {
      "parameters": {
        "sendTo": "={{ $('Webhook').item.json.body.email }}",
        "subject": "=Welcome to {{ $('Webhook').item.json.body.company }}!",
        "emailType": "html",
        "message": "=<h2>Welcome aboard, {{ $('Webhook').item.json.body.name }}!</h2>\n<p>We're thrilled to have <strong>{{ $('Webhook').item.json.body.company }}</strong> on the <strong>{{ $('Webhook').item.json.body.plan }}</strong> plan.</p>\n<p>Over the next few days, we'll send you everything you need to get started. In the meantime, here's what you can expect:</p>\n<ul>\n  <li>A dedicated folder has been created for your team in Google Drive.</li>\n  <li>Your account details have been recorded and our team has been notified.</li>\n  <li>You'll receive step-by-step guides to help you hit the ground running.</li>\n</ul>\n<p>If you have any questions, just reply to this email — we're here to help!</p>\n<p>Best regards,<br>The Onboarding Team</p>",
        "options": {}
      },
      "id": "gmail-welcome",
