      "name": "Gmail - Getting Started",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.1,
      "credentials": {
        "gmailOAuth2": {
          "id": "cred-gmail",
          "name": "Gmail OAuth2"
        }
      },
      "position": [1320, 0]
    },
