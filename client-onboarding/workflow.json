    },
    {
      "parameters": {
        "sendTo": "={{ $('Webhook').item.json.body.email }}",
        "subject": "How's everything going?",
        "emailType": "html",
        "message": "=<h2>Hi {{ $('Webhook').item.json.body.name }},</h2>\n<p>It's been about a week since {{ $('Webhook').item.json.body.company }} joined us, and we wanted to check in!</p>\n<p>We'd love to hear how things are going:</p>\n<ul>\n  <li>Were you able to set everything up smoothly?</li>\n  <li>Is there anything you need help with?</li>\n  <li>Do you have any feedback for us?</li>\n</ul>\n<p>Our support team is always available if you run into any issues. Just reply to this email or reach out to our support channel.</p>\n<p>We're committed to making sure you get the most out of your <strong>{{ $('Webhook').item.json.body.plan }}</strong> plan.</p>\n<p>Best,<br>The Onboarding Team</p>",
        "options": {}
      },
