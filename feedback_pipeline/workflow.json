      "id": "b2c1d002-0001-4000-8000-000000000009",
      "name": "📊 Sheets: Read All Feedback",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.7,
      "position": [460, 720],
      "credentials": {
        "googleApi": {
          "id": "cred-google-sheets",
          "name": "Google Sheets Service Account"
        }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Aggregate yesterday's feedback into a daily digest\nconst now = new Date();\nconst yesterday = new Date(now);\nyesterday.setDate(yesterday.getDate() - 1);\nconst startOfYesterday = new Date(yesterday.getFullYear(), yesterday.getMonth(), yesterday.getDate());\nconst endOfYesterday = new Date(startOfYesterday);\nendOfYesterday.setDate(endOfYesterday.getDate() + 1);\n\nconst allItems = $input.all();\nconst yesterdayItems = allItems.filter(item => {\n  const receivedAt = new Date(item.json.received_at);\n  return receivedAt >= startOfYesterday && receivedAt < endOfYesterday;\n});\n\nif (yesterdayItems.length === 0) {\n  return [{ json: { count: 0, has_data: false } }];\n}\n\nconst ratings = yesterdayItems.map(i => Number(i.json.rating)).filter(r => !isNaN(r));\nconst avgRating = ratings.length > 0\n  ? (ratings.reduce((a, b) => a + b, 0) / ratings.length).toFixed(1)\n  : 'N/A';\n\nconst urgent = yesterdayItems.filter(i => Number(i.json.rating) <= 2);\nconst positive = yesterdayItems.filter(i => Number(i.json.rating) >= 4);\n\nconst sources = {};\nyesterdayItems.forEach(i => {\n  const src = i.json.source || 'Unknown';\n  sources[src] = (sources[src] || 0) + 1;\n});\nconst sourceSummary = Object.entries(sources)\n  .map(([k, v]) => `${k}: ${v}`)\n  .join(', ');\n\nreturn [{\n  json: {\n    has_data: true,\n    count: yesterdayItems.length,\n    avg_rating: avgRating,\n    urgent_count: urgent.length,\n    positive_count: positive.length,\n    sources: sourceSummary,\n    date: startOfYesterday.toISOString().split('T')[0],\n    highlights: yesterdayItems.slice(0, 3).map(i => ({\n      name: i.json.name,\n      rating: i.json.rating,\n      message: (i.json.message || '').substring(0, 100)\n    }))\n  }\n}];"
      },
