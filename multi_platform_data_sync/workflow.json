      "id": "a1b0c001-0001-4000-8000-000000000004",
      "name": "🔎 Enrich Company Data",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [880, 460],
      "credentials": {
        "httpHeaderAuth": {
          "id": "cred-enrichment-api",
          "name": "Enrichment API Key"
        }
      },
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Merge original lead data with enrichment results\nconst lead = $('🔍 Filter New Leads').item.json;\nconst enrichment = $input.item.json;\n\n// Calculate lead score based on enrichment data\nlet score = 0;\n\n// Company size scoring\nconst employees = enrichment.employees || 0;\nif (employees > 500) score += 30;\nelse if (employees > 100) score += 20;\nelse if (employees > 20) score += 10;\n\n// Industry scoring (high-value verticals)\nconst highValueIndustries = ['technology', 'finance', 'healthcare', 'saas'];\nconst industry = (enrichment.industry || '').toLowerCase();\nif (highValueIndustries.includes(industry)) score += 25;\nelse score += 10;\n\n// Data completeness scoring\nif (enrichment.linkedin_url) score += 10;\nif (enrichment.phone) score += 10;\nif (enrichment.revenue) score += 15;\n\nreturn {\n  json: {\n    // Original lead fields\n    name: lead.name,\n    email: lead.email,\n    company: lead.company,\n    company_domain: lead.company_domain,\n    source: lead.source,\n    row_number: lead.row_number,\n\n    // Enriched fields\n    industry: enrichment.industry || 'Unknown',\n    employees: employees,\n    revenue: enrichment.revenue || 'Unknown',\n    linkedin_url: enrichment.linkedin_url || '',\n    phone: enrichment.phone || '',\n    headquarters: enrichment.headquarters || '',\n    description: enrichment.description || '',\n\n    // Computed fields\n    lead_score: score,\n    qualification: score >= 50 ? 'Qualified' : 'Needs Nurturing',\n    enriched_at: new Date().toISOString(),\n    synced: true\n  }\n};"
      },
      "id": "a1b0c001-0001-4000-8000-000000000005",
      "name": "⚙️ Transform & Score",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1100, 460]
    },
    {
      "parameters": {
