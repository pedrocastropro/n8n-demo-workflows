        "otherOptions": {}
      },
      "id": "c3d2e003-0001-4000-8000-000000000012",
      "name": "🔥 Slack: Workflow Error",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2.3,
      "position": [460, 900],
      "credentials": {
