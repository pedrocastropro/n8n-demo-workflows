{
  "id": "resilient-api-pipeline",
  "name": "Resilient API Pipeline — Error Handling & Fallback",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours",
              "hoursInterval": 4
            }
          ]
        }
      },
      "id": "c3d2e003-0001-4000-8000-000000000001",
      "name": "⏰ Every 4 Hours",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [240, 460]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://api.external-service.com/v1/data",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "httpHeaderAuth",
        "options": {
          "timeout": 15000
        },
        "retry": {
          "maxRetries": 3,
          "retryInterval": 2000,
          "retryOnTimeout": true
        }
      },
      "id": "c3d2e003-0001-4000-8000-000000000002",
      "name": "🌐 Fetch API Data",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [460, 460],
      "credentials": {
        "httpHeaderAuth": {
          "id": "cred-external-api",
          "name": "External API Key"
        }
      },
      "onError": "continueErrorOutput",
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Validate and transform API response\nconst response = $input.item.json;\n\n// Check for error indicators in the response\nif (response.error || response.statusCode >= 400) {\n  throw new Error(`API returned error: ${response.error || response.statusMessage || 'Unknown'}`);\n}\n\n// Validate required fields\nconst data = response.data || response;\nif (!data) {\n  throw new Error('Empty response from API');\n}\n\nconst items = Array.isArray(data) ? data : [data];\n\nreturn items.map(item => ({\n  json: {\n    id: item.id || `auto_${Date.now()}`,\n    metric: item.metric || item.name || 'unknown',\n    value: Number(item.value) || 0,\n    unit: item.unit || '',\n    source: 'primary_api',\n    fetched_at: new Date().toISOString(),\n    api_timestamp: response.timestamp || new Date().toISOString(),\n    is_anomaly: item.value != null && Math.abs(Number(item.value)) > (item.threshold || 100)\n  }\n}));"
      },
      "id": "c3d2e003-0001-4000-8000-000000000003",
      "name": "⚙️ Validate & Transform",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [740, 340]
    },
    {
      "parameters": {
        "operation": "append",
        "documentId": {
          "__rl": true,
          "mode": "url",
          "value": "https://docs.google.com/spreadsheets/d/YOUR_SPREADSHEET_ID/edit"
        },
        "sheetName": {
          "__rl": true,
          "mode": "list",
          "value": "gid=0",
          "cachedResultName": "API Data"
        },
        "columns": {
          "mappingMode": "autoMapInputData",
          "value": {}
        },
        "options": {}
      },
      "id": "c3d2e003-0001-4000-8000-000000000004",
      "name": "📊 Sheets: Store Data",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.7,
      "position": [960, 340],
      "credentials": {
        "googleApi": {
          "id": "cred-google-sheets",
          "name": "Google Sheets Service Account"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "check-anomaly",
              "leftValue": "={{ $json.is_anomaly }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "c3d2e003-0001-4000-8000-000000000005",
      "name": "🎯 Anomaly Detected?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [1180, 340]
    },
    {
      "parameters": {
        "channel": "#api-alerts",
        "text": "=⚠️ *Anomaly Detected*\n\n📊 Metric: *{{ $json.metric }}*\n📈 Value: {{ $json.value }} {{ $json.unit }}\n🕐 {{ $json.fetched_at }}\n🔗 Source: {{ $json.source }}\n\nThis value exceeds the expected threshold. Please investigate.",
        "otherOptions": {}
      },
      "id": "c3d2e003-0001-4000-8000-000000000006",
      "name": "⚠️ Slack: Anomaly Alert",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2.3,
      "position": [1400, 240],
      "credentials": {
        "slackOAuth2Api": {
          "id": "cred-slack",
          "name": "Slack OAuth2"
        }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Extract error details from the failed HTTP request\nconst error = $input.item.json;\n\nreturn {\n  json: {\n    error_type: error.code || error.statusCode || 'UNKNOWN_ERROR',\n    error_message: error.message || error.statusMessage || JSON.stringify(error).substring(0, 500),\n    endpoint: 'primary_api',\n    url: 'https://api.external-service.com/v1/data',\n    occurred_at: new Date().toISOString(),\n    retries_exhausted: 3,\n    workflow: 'Resilient API Pipeline'\n  }\n};"
      },
      "id": "c3d2e003-0001-4000-8000-000000000007",
      "name": "❌ Format Error Details",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [740, 620]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://api.fallback-service.com/v1/data",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "httpHeaderAuth",
        "options": {
          "timeout": 10000
        }
      },
      "id": "c3d2e003-0001-4000-8000-000000000008",
      "name": "🔄 Fallback API",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [960, 620],
      "credentials": {
        "httpHeaderAuth": {
          "id": "cred-external-api",
